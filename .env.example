# =====================================================
# Auth & App
# =====================================================
JWT_SECRET=change_this_to_a_long_random_string
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# =====================================================
# Databases
# =====================================================
POSTGRES_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_db
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# =====================================================
# Storage (MinIO / S3)
# =====================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-files
MINIO_SECURE=false

# =====================================================
# LLM Routing (LiteLLM — endpoints & keys only)
# No LLM/VLM model names here. Selection is dynamic
# via workspace.model_prefs + API payload overrides.
# =====================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234
LITELLM_DEFAULT_TIMEOUT=30
LITELLM_MAX_RETRIES=2

# =====================================================
# Code Sandbox
# =====================================================
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=30
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_NETWORK_ENABLED=false

# =====================================================
# Extraction & Validation (generic parameters)
# =====================================================
VLM_TEMPERATURE=0.2
OCR_FALLBACK_THRESHOLD=0.65
MAX_CONTEXT_TOKENS=8192
ENABLE_SEMANTIC_CACHE=true
